# ═══════════════════════════════════════════════════════════════
# Samba Panel — Environment Configuration
# Copy to .env and fill in the required values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED (no defaults — must be set) ────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32

# Generate with: openssl rand -hex 32
CSRF_SECRET=change_me_generate_with_openssl_rand_hex_32

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8090
ENVIRONMENT=production  # development | production

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=/var/lib/sambaguard/panel.db

# ── Samba ────────────────────────────────────────────────────────────────────
SMB_CONF_PATH=/etc/samba/smb.conf
SMB_STAGING_PATH=/var/lib/sambaguard/smb.conf.staging
SMB_BACKUP_DIR=/var/lib/sambaguard/backups

# ── Security ─────────────────────────────────────────────────────────────────
BCRYPT_COST=12                    # 10-14; higher = slower but more secure
JWT_ACCESS_EXPIRY_MINUTES=15      # Short-lived access token
JWT_REFRESH_EXPIRY_HOURS=168      # 7 days
RATE_LIMIT_LOGIN_ATTEMPTS=5       # Max failed logins before lockout
RATE_LIMIT_WINDOW_SECONDS=900     # Lockout window (15 minutes)
SESSION_TIMEOUT_MINUTES=60

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info                    # debug | info | warn | error
AUDIT_FILE=/var/log/sambaguard/audit.log

# ── TLS (optional — recommended in production) ────────────────────────────────
# TLS_CERT_FILE=/etc/ssl/certs/sambaguard.crt
# TLS_KEY_FILE=/etc/ssl/private/sambaguard.key

# ── First-run admin bootstrap ─────────────────────────────────────────────────
# The admin account is created on first run if no panel users exist.
# If INIT_ADMIN_PASS is empty, a random password is generated and printed to logs.
INIT_ADMIN_USER=admin
INIT_ADMIN_PASS=                  # Leave empty to auto-generate (recommended)
